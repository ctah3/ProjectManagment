@model ProjectManagment_class.Models.Project

@{
    ViewData["Title"] = "Деталі";
}

<h1>Деталі проєкту</h1>

<div>

    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ProjectName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ProjectName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DateStart)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DateStart)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DateEnd)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DateEnd)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Manager)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Manager.Email)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ProjectId)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ProjectId)
        </dd>
        <dt class="col-sm-2">
            Учасники
        </dt>
        <dd class="col-sm-10">
            @if (Model.ProjectMembers != null && Model.ProjectMembers.Any())
            {
                @string.Join(", ", Model.ProjectMembers.Select(pm => pm.User?.Email))
            }
            else
            {
                <span>Немає учасників</span>
            }
        </dd>

        <dt class="col-sm-2">
            Завдання
        </dt>
        <dd class="col-sm-10">
            @if (Model.Tasks != null && Model.Tasks.Any())
            {
                @string.Join(", ", Model.Tasks.Select(t => t.Title))
            }
            else
            {
                <span>Немає завдань</span>
            }
        </dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.ProjectId">Редагувати</a> |
    <a asp-action="Index">Повернутись</a>
</div>
